# =============================================================
# CuraSense — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All services read from this single .env file via docker-compose.
# =============================================================

# --- External API Keys (Free Tier) ---
# Google Gemini API — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Groq API — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Tavily Search API — https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# HuggingFace Token — https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Google Cloud credentials (base64-encoded service account JSON)
# Used by ml-fastapi for vision features
# Generate: base64 -w 0 service-account.json
GOOGLE_CREDENTIALS_BASE64=your_base64_encoded_credentials_here

# --- Database ---
# NeonDB PostgreSQL connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/curasense?sslmode=require

# --- Auth ---
# JWT secret for session tokens (generate: openssl rand -base64 64)
JWT_SECRET=your_jwt_secret_here_at_least_64_chars

# Cron secret for scheduled jobs
CRON_SECRET=your_cron_secret_here

# --- Frontend ---
# Public URL for password reset links and NEXT_PUBLIC_* vars
# On EC2: http://<ec2-public-ip>:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
